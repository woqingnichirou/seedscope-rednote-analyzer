<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ report_title | default("Brand A vs Brand B 小红书种草竞品分析报告") }}</title>
  <style>
    :root {
      color-scheme: light;
      --text: #171717;
      --muted: #666666;
      --line: #dddddd;
      --soft: #f7f7f7;
      --accent: #b42318;
      --accent-soft: #fff1ef;
    }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", Arial, sans-serif;
      color: var(--text);
      background: #ffffff;
      line-height: 1.6;
    }
    main {
      max-width: 1120px;
      margin: 0 auto;
      padding: 40px 28px 64px;
    }
    h1 {
      margin: 0 0 12px;
      font-size: 32px;
      line-height: 1.25;
      letter-spacing: 0;
    }
    h2 {
      margin: 40px 0 16px;
      padding-top: 20px;
      border-top: 1px solid var(--line);
      font-size: 22px;
      letter-spacing: 0;
    }
    h3 {
      margin: 24px 0 8px;
      font-size: 17px;
      letter-spacing: 0;
    }
    p {
      margin: 8px 0 14px;
    }
    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 16px;
      margin: 0 0 28px;
      color: var(--muted);
      font-size: 14px;
    }
    .summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
      margin: 18px 0;
    }
    .summary-item {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 16px;
      background: var(--soft);
    }
    .summary-item strong {
      display: block;
      margin-bottom: 8px;
      color: var(--accent);
      font-size: 16px;
    }
    .callout {
      border-left: 4px solid var(--accent);
      background: var(--accent-soft);
      padding: 12px 16px;
      margin: 16px 0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 12px 0 22px;
      font-size: 14px;
    }
    th, td {
      border: 1px solid var(--line);
      padding: 10px 12px;
      vertical-align: top;
      text-align: left;
    }
    th {
      background: var(--soft);
      font-weight: 700;
    }
    ul, ol {
      padding-left: 22px;
    }
    .muted {
      color: var(--muted);
    }
    @media (max-width: 720px) {
      main {
        padding: 28px 16px 44px;
      }
      h1 {
        font-size: 26px;
      }
      table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
    }
  </style>
</head>
<body>
<main>
  <h1>{{ report_title | default("Brand A vs Brand B 小红书种草竞品分析报告") }}</h1>
  <div class="meta">
    <span>分析周期：{{ period.label }}</span>
    <span>优化对象：{{ brand_a.name | default("Brand A") }}</span>
    <span>对标对象：{{ brand_b.name | default("Brand B") }}</span>
  </div>

  <section>
    <h2>核心结论</h2>
    <div class="summary">
      {% for insight in executive_summary.insights %}
      <article class="summary-item">
        <strong>{{ insight.title }}</strong>
        <p>{{ insight.summary }}</p>
        <p class="muted">证据：{{ insight.evidence }}</p>
        <p>启示：{{ insight.implication }}</p>
      </article>
      {% endfor %}
    </div>
    <div class="callout">{{ executive_summary.overall_judgement }}</div>
  </section>

  <section>
    <h2>近半年概览</h2>
    <p>{{ overview.conclusion }}</p>
    <table>
      <thead><tr><th>指标</th><th>{{ brand_a.name | default("Brand A") }}</th><th>{{ brand_b.name | default("Brand B") }}</th><th>关键判断</th></tr></thead>
      <tbody>
      {% for row in overview.metrics %}
      <tr><td>{{ row.name }}</td><td>{{ row.brand_a }}</td><td>{{ row.brand_b }}</td><td>{{ row.comment }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    {% if overview.key_observations %}
    <ul>{% for item in overview.key_observations %}<li>{{ item }}</li>{% endfor %}</ul>
    {% endif %}
  </section>

  <section>
    <h2>发布时间节奏</h2>
    <p>{{ cadence.conclusion }}</p>
    <table>
      <thead><tr><th>时间窗口</th><th>{{ brand_a.name | default("Brand A") }} 动作</th><th>{{ brand_b.name | default("Brand B") }} 动作</th><th>策略含义</th></tr></thead>
      <tbody>
      {% for row in cadence.timeline %}
      <tr><td>{{ row.window }}</td><td>{{ row.brand_a_action }}</td><td>{{ row.brand_b_action }}</td><td>{{ row.interpretation }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    <div class="callout">{{ cadence.recommendation }}</div>
  </section>

  <section>
    <h2>花费与达人结构</h2>
    <p>{{ spend_and_creators.conclusion }}</p>
    <table>
      <thead><tr><th>达人层级</th><th>定义</th><th>当前占比/数量</th><th>表现判断</th><th>下一步动作</th></tr></thead>
      <tbody>
      {% for tier in spend_and_creators.creator_tiers %}
      <tr><td>{{ tier.name }}</td><td>{{ tier.definition }}</td><td>{{ tier.share }}</td><td>{{ tier.performance }}</td><td>{{ tier.action }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    {% if spend_and_creators.price_bands %}
    <table>
      <thead><tr><th>价格带</th><th>合作数量</th><th>花费占比</th><th>角色判断</th></tr></thead>
      <tbody>
      {% for band in spend_and_creators.price_bands %}
      <tr><td>{{ band.label }}</td><td>{{ band.count }}</td><td>{{ band.spend_share }}</td><td>{{ band.role }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    {% endif %}
  </section>

  <section>
    <h2>标题结构对比</h2>
    <p>{{ title_analysis.conclusion }}</p>
    <table>
      <thead><tr><th>标题类型</th><th>{{ brand_a.name | default("Brand A") }} 占比</th><th>{{ brand_b.name | default("Brand B") }} 占比</th><th>表现判断</th><th>可复用公式</th></tr></thead>
      <tbody>
      {% for item in title_analysis.types %}
      <tr><td>{{ item.type }}</td><td>{{ item.brand_a_share }}</td><td>{{ item.brand_b_share }}</td><td>{{ item.finding }}</td><td>{{ item.formula }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    <div class="callout">{{ title_analysis.recommendation }}</div>
  </section>

  <section>
    <h2>内容策略对比</h2>
    <p>{{ content_strategy.conclusion }}</p>
    <table>
      <thead><tr><th>维度</th><th>{{ brand_a.name | default("Brand A") }}</th><th>{{ brand_b.name | default("Brand B") }}</th><th>优化点</th></tr></thead>
      <tbody>
      {% for row in content_strategy.dimensions %}
      <tr><td>{{ row.dimension }}</td><td>{{ row.brand_a }}</td><td>{{ row.brand_b }}</td><td>{{ row.optimization }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>正文结构拆解</h2>
    <p>{{ body_structure.conclusion }}</p>
    <table>
      <thead><tr><th>步骤</th><th>目标</th><th>推荐写法</th><th>需要填充的数据</th></tr></thead>
      <tbody>
      {% for step in body_structure.steps %}
      <tr><td>{{ loop.index }}. {{ step.name }}</td><td>{{ step.goal }}</td><td>{{ step.guidance }}</td><td>{{ step.required_data }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>高赞内容类别</h2>
    <p>{{ high_like_categories.conclusion }}</p>
    <table>
      <thead><tr><th>类别</th><th>用户问题</th><th>内容抓手</th><th>标题方向</th><th>封面方向</th><th>适用作者</th></tr></thead>
      <tbody>
      {% for category in high_like_categories.items %}
      <tr><td>{{ category.name }}</td><td>{{ category.user_question }}</td><td>{{ category.content_hook }}</td><td>{{ category.title_direction }}</td><td>{{ category.cover_direction }}</td><td>{{ category.creator_fit }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>封面策略拆解</h2>
    <p>{{ cover_strategy.conclusion }}</p>
    <table>
      <thead><tr><th>封面模板</th><th>核心信息</th><th>视觉证据</th><th>适用内容</th><th>验收标准</th></tr></thead>
      <tbody>
      {% for template in cover_strategy.templates %}
      <tr><td>{{ template.name }}</td><td>{{ template.message }}</td><td>{{ template.evidence_slot }}</td><td>{{ template.content_fit }}</td><td>{{ template.acceptance_criteria }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>CTA 承接分析</h2>
    <p>{{ cta_analysis.conclusion }}</p>
    <table>
      <thead><tr><th>CTA 位置</th><th>当前表现</th><th>用户问题</th><th>优化动作</th><th>监测指标</th></tr></thead>
      <tbody>
      {% for row in cta_analysis.touchpoints %}
      <tr><td>{{ row.position }}</td><td>{{ row.current_state }}</td><td>{{ row.user_question }}</td><td>{{ row.action }}</td><td>{{ row.metric }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>当前问题总结</h2>
    <table>
      <thead><tr><th>层级</th><th>问题</th><th>影响</th><th>优先级</th><th>对应动作</th></tr></thead>
      <tbody>
      {% for issue in issues %}
      <tr><td>{{ issue.layer }}</td><td>{{ issue.problem }}</td><td>{{ issue.impact }}</td><td>P{{ issue.priority }}</td><td>{{ issue.action }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>优化措施汇总</h2>
    {% for initiative in optimization_initiatives %}
    <h3>{{ initiative.name }}</h3>
    <p>{{ initiative.objective }}</p>
    <table>
      <thead><tr><th>动作</th><th>交付物</th><th>验收指标</th></tr></thead>
      <tbody>
      {% for action in initiative.actions %}
      <tr><td>{{ action.name }}</td><td>{{ action.deliverable }}</td><td>{{ action.acceptance_metric }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    {% endfor %}
  </section>

  <section>
    <h2>下阶段打法</h2>
    <table>
      <thead><tr><th>阶段</th><th>时间窗口</th><th>核心任务</th><th>关键产物</th><th>判断标准</th></tr></thead>
      <tbody>
      {% for phase in next_stage_plan.phases %}
      <tr><td>{{ phase.name }}</td><td>{{ phase.window }}</td><td>{{ phase.task }}</td><td>{{ phase.deliverable }}</td><td>{{ phase.success_metric }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>预算分配建议</h2>
    <p>{{ budget_plan.conclusion }}</p>
    <table>
      <thead><tr><th>投放模块</th><th>建议占比</th><th>目标</th><th>执行原则</th></tr></thead>
      <tbody>
      {% for item in budget_plan.allocation %}
      <tr><td>{{ item.module }}</td><td>{{ item.share }}</td><td>{{ item.goal }}</td><td>{{ item.principle }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>下一步行动</h2>
    <table>
      <thead><tr><th>序号</th><th>动作</th><th>负责人</th><th>截止时间</th><th>交付物</th><th>验收指标</th></tr></thead>
      <tbody>
      {% for action in next_actions %}
      <tr><td>{{ loop.index }}</td><td>{{ action.name }}</td><td>{{ action.owner }}</td><td>{{ action.due_date }}</td><td>{{ action.deliverable }}</td><td>{{ action.metric }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
</main>
</body>
</html>
