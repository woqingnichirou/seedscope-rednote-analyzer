      "purpose": "用 3-5 条结论概括双方策略差异和 Brand A 的优先动作。",
      "data_contract": {
        "overall_judgement": "string",
        "insights": [
          {
            "title": "string",
            "summary": "string",
            "evidence": "string",
            "implication": "string"
          }
        ]
      },
      "quality_checks": [
        "结论必须包含策略差异",
        "至少一条结论指向 Brand A 的优化动作",
        "不得出现真实品牌名或真实预算"
      ]
    },
    {
      "id": "overview",
      "title": "近半年概览",
      "required": true,
      "purpose": "聚合展示发布规模、互动表现、爆文率、内容类型和主要波峰。",
      "data_contract": {
        "conclusion": "string",
        "metrics": [
          {
            "name": "string",
            "brand_a": "number|string",
            "brand_b": "number|string",
            "comment": "string"
          }
        ],
        "key_observations": ["string"]
      },
      "recommended_metrics": [
        "发布笔记数",
        "总互动量",
        "平均互动量",
        "高赞内容数",
        "爆文率",
        "品牌直露标题占比",
        "问题型/方法型标题占比"
