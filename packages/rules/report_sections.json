  "validation_rules": [
    {
      "id": "no_real_brand_names",
      "description": "输出中不得包含原始真实品牌名。",
      "severity": "error"
    },
    {
      "id": "no_raw_budget",
      "description": "输出中不得包含原始真实预算金额，只允许区间、占比或变量。",
      "severity": "error"
    },
    {
      "id": "conclusion_first",
      "description": "每个章节第一段应为结论或判断，不应先列原始数据。",
      "severity": "warning"
    },
    {
      "id": "actionable_recommendations",
      "description": "所有优化建议必须包含动作、交付物或指标。",
      "severity": "warning"
    }
  ]
