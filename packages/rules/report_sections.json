      "required": true,
      "purpose": "识别双方发布波峰、低谷和内容主题之间的关系。",
      "data_contract": {
        "conclusion": "string",
        "timeline": [
          {
            "window": "string",
            "brand_a_action": "string",
            "brand_b_action": "string",
            "interpretation": "string"
          }
        ],
        "recommendation": "string"
      },
      "quality_checks": [
        "不能只比较发布数量",
        "必须解释波峰背后的内容主题或投放目标"
