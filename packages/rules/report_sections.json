{
  "template_name": "brand_a_vs_brand_b_xiaohongshu_seeding_competitive_analysis",
  "version": "1.0.0",
  "language": "zh-CN",
  "privacy_rules": {
    "brand_replacement": {
      "optimized_brand": "Brand A",
      "benchmark_brand": "Brand B"
    },
    "forbidden_content": [
      "真实品牌名",
      "真实预算金额",
      "真实达人姓名或账号",
      "真实截图",
      "可识别的原始案例标题"
    ],
    "allowed_content": [
      "脱敏后的占比",
      "区间化金额",
      "抽象后的标题公式",
      "不可识别的内容母题",
      "聚合指标"
    ]
  },
  "rendering_principles": [
    "结论先行",
    "每节包含结论、证据、动作",
    "使用 Brand A 和 Brand B 作为默认品牌名",
    "建议必须对应可执行产物或可监测指标",
    "不输出空泛建议"
  ],
  "required_context": {
    "period": {
      "label": "分析周期展示名，例如：近半年"
    },
    "brand_a": {
      "name": "Brand A",
      "role": "优化对象"
    },
    "brand_b": {
      "name": "Brand B",
      "role": "对标对象"
    }
  },
  "sections": [
    {
      "id": "executive_summary",
      "title": "核心结论",
