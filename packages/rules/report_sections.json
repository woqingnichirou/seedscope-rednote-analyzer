          {
            "name": "string",
            "definition": "string",
            "share": "string",
            "performance": "string",
            "action": "string"
          }
        ],
        "price_bands": [
          {
            "label": "string",
            "count": "number|string",
            "spend_share": "string",
            "role": "string"
          }
        ]
